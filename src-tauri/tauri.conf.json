{
  "$schema": "https://schema.tauri.app/config/2",
  "version": "0.2.1",
  "identifier": "com.mailcleaner.app",
  "mainBinaryName": "Mail Cleaner",
  "productName": "Mail Cleaner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Mail Cleaner",
        "width": 1700,
        "height": 900,
        "minWidth": 520,
        "minHeight": 500,
        "acceptFirstMouse": false,
        "center": true,
        "dragDropEnabled": false,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/mailcleaner_logo.jpg",
      "icons/mailcleaner_logo.ico",
      "icons/mailcleaner_logo.png"
    ],
    "longDescription": "Mail Cleaner is a tool that helps you clean your email inbox.",
    "shortDescription": "Mail Cleaner is a tool that helps you clean your email inbox.",
    "publisher": "https://github.com/LouisDerveloy"
  }
}
